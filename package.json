{
	"name": "@sondr3/frontend-config",
	"version": "1.0.0",
	"private": true,
	"description": "My shared configuration files",
	"license": "MIT",
	"author": "Sondre Aasemoen <sondre@eons.io> (https://www.eons.io)",
	"repository": "https://github.com/sondr3/frontend-config",
	"workspaces": [
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"format": "oxfmt",
		"format:fix": "oxfmt --fix",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"prepublish": "pnpm format",
		"changeset": "changeset",
		"version-packages": "changeset version",
		"release": "changeset publish"
	},
	"devDependencies": {
		"@changesets/cli": "2.29.6",
		"@sondr3/oxfmt": "workspace:*",
		"@sondr3/oxlint": "workspace:*",
		"oxfmt": "0.44.0",
		"oxlint": "1.59.0"
	},
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "^24.14.1",
			"onFail": "download"
		}
	},
	"engines": {
		"node": ">= 24",
		"pnpm": ">= 10"
	},
	"packageManager": "pnpm@10.33.0"
}
