{
	"name": "@sondr3/renovate-config",
	"version": "0.5.0",
	"description": "Renovate configuration for @sondr3",
	"keywords": [
		"renovate",
		"renovate-config"
	],
	"license": "MIT",
	"author": "Sondre Aasemoen <sondre@eons.io> (https://www.eons.io)",
	"repository": "https://github.com/sondr3/frontend-config",
	"files": [],
	"publishConfig": {
		"access": "public"
	},
	"renovate-config": {
		"default": {
			"description": "Renovate configuration for @sondr3",
			"extends": [
				"config:base",
				":enableVulnerabilityAlertsWithLabel(security)",
				":automergeMinor",
				":automergeBranch",
				":rebaseStalePrs",
				":prNotPending",
				":disableRateLimiting",
				":docker",
				":label(renovate)",
				":pinAllExceptPeerDependencies",
				":maintainLockFilesWeekly"
			],
			"dependencyDashboard": true,
			"major": {
				"automerge": false
			},
			"stabilityDays": 3,
			"prNotPendingHours": 24,
			"packageRules": [
				{
					"packagePatterns": [
						"^@sondr3"
					],
					"groupName": "personal packages"
				}
			]
		}
	}
}
